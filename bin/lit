#!/bin/bash
# lit.sh - Literature search tool for academic papers
#
# Smart input detection - just paste anything:
#   lit.sh 2006.11239                    → arXiv lookup
#   lit.sh 10.1145/3442188.3445899       → DOI lookup
#   lit.sh https://arxiv.org/abs/2006.11239  → arXiv lookup
#   lit.sh https://doi.org/10.1145/...   → DOI lookup
#   lit.sh 978-0262039246                → ISBN lookup
#   lit.sh "attention is all you need"   → search
#
# Explicit commands:
#   search <query>       - Search papers (Semantic Scholar → OpenAlex → OpenLibrary)
#   dblp <query>         - Search DBLP for CS venue papers
#   dblp-bib <url>       - Get BibTeX from DBLP URL
#   doi <doi>            - Lookup paper metadata by DOI (CrossRef)
#   bibtex <doi>         - Get BibTeX entry for DOI (CrossRef)
#   isbn <isbn>          - Lookup book by ISBN (OpenLibrary)
#   book <query>         - Search books by title/author (OpenLibrary)
#   arxiv <id>           - Get arXiv paper info + BibTeX + PDF link
#   source <arxiv_id>    - Download arXiv LaTeX source
#   pdf <doi>            - Find open-access PDF via Unpaywall
#   refs <paper_id>      - Get references of a paper
#   cites <paper_id>     - Get papers that cite this paper
#   open <id>            - Open paper in browser
#   add <id> <bib_file>  - Fetch BibTeX and append to .bib file
#   verify <bib_file>    - Verify all entries in a .bib file
#
# Environment:
#   LIT_CACHE_DIR        - Cache directory (default: etc/lit/cache)
#   CURL_TIMEOUT         - Request timeout in seconds (default: 15)

set -euo pipefail

# Colors - auto-disable when piped (LLM-friendly)
if [ -t 1 ] && [ -t 2 ]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[0;33m'
    BLUE='\033[0;34m'
    BOLD='\033[1m'
    NC='\033[0m'
else
    RED='' GREEN='' YELLOW='' BLUE='' BOLD='' NC=''
fi

# Config
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CACHE_DIR="${LIT_CACHE_DIR:-$SCRIPT_DIR/../etc/lit/cache}"
CURL_TIMEOUT="${CURL_TIMEOUT:-15}"
CACHE_TTL_SEARCH=86400   # 24 hours for search results
CACHE_TTL_DOI=604800     # 7 days for DOI lookups
VERBOSE="${VERBOSE:-0}"  # 0=concise, 1=verbose
BIB_FILE=""              # --bib FILE: append BibTeX to file

mkdir -p "$CACHE_DIR"

# Logging helpers - decorative text to stderr, data to stdout
info() { echo -e "${BLUE}$*${NC}" >&2; }
warn() { echo -e "${YELLOW}$*${NC}" >&2; }
err()  { echo -e "${RED}$*${NC}" >&2; }

# URL encoding - safe for all input
urlencode() {
    python3 -c "import sys, urllib.parse; print(urllib.parse.quote(sys.stdin.read().strip(), safe=''))" <<< "$1"
}

# Sanitize string for use as cache filename
cache_key() {
    echo "$1" | md5 | cut -c1-16
}

# Cached curl - uses file-based cache
cached_curl() {
    local key="$1"
    local url="$2"
    local ttl="${3:-$CACHE_TTL_SEARCH}"
    local cache_file="$CACHE_DIR/${key}"

    # Check cache
    if [ -f "$cache_file" ]; then
        local age=$(($(date +%s) - $(stat -f %m "$cache_file" 2>/dev/null || stat -c %Y "$cache_file" 2>/dev/null || echo 0)))
        if [ "$age" -lt "$ttl" ]; then
            cat "$cache_file"
            return 0
        fi
    fi

    # Fetch and cache
    local result
    result=$(curl -s --max-time "$CURL_TIMEOUT" "$url" 2>/dev/null || echo "")
    if [ -n "$result" ]; then
        echo "$result" > "$cache_file"
    fi
    echo "$result"
}

# ── Input detection ──────────────────────────────────────────────────

# Extract arXiv ID from various formats
normalize_arxiv() {
    local input="$1"
    # Strip URL prefixes
    input="${input#https://arxiv.org/abs/}"
    input="${input#http://arxiv.org/abs/}"
    input="${input#https://arxiv.org/pdf/}"
    input="${input#http://arxiv.org/pdf/}"
    input="${input#https://export.arxiv.org/abs/}"
    # Strip arXiv: prefix
    input="${input#arXiv:}"
    input="${input#arxiv:}"
    # Strip version suffix
    input=$(echo "$input" | sed 's/v[0-9]*$//')
    # Strip .pdf suffix
    input="${input%.pdf}"
    echo "$input"
}

# Extract DOI from various formats
normalize_doi() {
    local input="$1"
    input="${input#https://doi.org/}"
    input="${input#http://doi.org/}"
    input="${input#https://dx.doi.org/}"
    input="${input#http://dx.doi.org/}"
    echo "$input"
}

# Detect input type and route to handler
# Returns: arxiv|doi|isbn|dblp_url|search
detect_type() {
    local input="$1"

    # arXiv URL
    if [[ "$input" =~ ^https?://([a-z]+\.)?arxiv\.org/ ]]; then
        echo "arxiv"
        return
    fi

    # DOI URL
    if [[ "$input" =~ ^https?://(dx\.)?doi\.org/ ]]; then
        echo "doi"
        return
    fi

    # DBLP URL
    if [[ "$input" =~ ^https?://dblp\.org/ ]]; then
        echo "dblp_url"
        return
    fi

    # Semantic Scholar URL
    if [[ "$input" =~ ^https?://www\.semanticscholar\.org/ ]]; then
        echo "ss_url"
        return
    fi

    # arXiv ID: YYMM.NNNNN or category/NNNNNNN
    if [[ "$input" =~ ^(arXiv:|arxiv:)?[0-9]{4}\.[0-9]{4,5}(v[0-9]+)?$ ]]; then
        echo "arxiv"
        return
    fi
    if [[ "$input" =~ ^[a-z-]+/[0-9]{7}$ ]]; then
        echo "arxiv"
        return
    fi

    # DOI: 10.NNNN/...
    if [[ "$input" =~ ^10\.[0-9]{4,}/ ]]; then
        echo "doi"
        return
    fi

    # ISBN: 10 or 13 digits (with optional hyphens)
    local stripped=$(echo "$input" | tr -d '\-' | tr -d ' ')
    if [[ "$stripped" =~ ^[0-9]{10}$ ]] || [[ "$stripped" =~ ^[0-9]{13}$ ]]; then
        echo "isbn"
        return
    fi

    echo "search"
}

# ── Commands ─────────────────────────────────────────────────────────

# Search Semantic Scholar
cmd_search_ss() {
    local query="$1"
    local limit="${2:-10}"
    local encoded=$(urlencode "$query")
    local url="https://api.semanticscholar.org/graph/v1/paper/search?query=${encoded}&limit=${limit}&fields=title,authors,year,citationCount,externalIds"

    cached_curl "ss_$(cache_key "$query")" "$url" "$CACHE_TTL_SEARCH" | python3 -c "
import sys, json
verbose = $VERBOSE
try:
    data = json.load(sys.stdin)
    papers = data.get('data', [])
    if not papers:
        sys.exit(1)
    for i, p in enumerate(papers[:10], 1):
        title = p.get('title', 'N/A')
        year = p.get('year', '?')
        authors = p.get('authors', [])
        author = authors[0]['name'].split()[-1] if authors else '?'
        cites = p.get('citationCount', 0)
        arxiv = p.get('externalIds', {}).get('ArXiv', '')
        doi = p.get('externalIds', {}).get('DOI', '')
        id_str = f'arXiv:{arxiv}' if arxiv else (f'DOI:{doi}' if doi else '')
        if verbose:
            print(f'{i}. {title} ({year})')
            print(f'   Author: {author} | Citations: {cites}')
            if arxiv: print(f'   arXiv: {arxiv}')
            if doi: print(f'   DOI: {doi}')
            print()
        else:
            t = title if len(title) <= 70 else title[:67] + '...'
            print(f'{i}. {author} {year} | {t} | {id_str}')
except:
    sys.exit(1)
"
}

# Search OpenAlex
cmd_search_openalex() {
    local query="$1"
    local limit="${2:-10}"
    local encoded=$(urlencode "$query")
    local url="https://api.openalex.org/works?search=${encoded}&per-page=${limit}"

    cached_curl "oa_$(cache_key "$query")" "$url" "$CACHE_TTL_SEARCH" | python3 -c "
import sys, json, re
verbose = $VERBOSE
def strip_html(s):
    return re.sub(r'<[^>]+>', '', s) if s else s
try:
    data = json.load(sys.stdin)
    works = data.get('results', [])
    if not works:
        sys.exit(1)
    for i, w in enumerate(works[:10], 1):
        title = strip_html(w.get('title', 'N/A'))
        year = w.get('publication_year', '?')
        authors = w.get('authorships', [])
        author = authors[0]['author']['display_name'].split()[-1] if authors else '?'
        cites = w.get('cited_by_count', 0)
        doi = w.get('doi', '').replace('https://doi.org/', '') if w.get('doi') else ''
        if verbose:
            print(f'{i}. {title} ({year})')
            print(f'   Author: {author} | Citations: {cites}')
            if doi: print(f'   DOI: {doi}')
            print()
        else:
            id_str = f'DOI:{doi}' if doi else ''
            t = title if len(title) <= 70 else title[:67] + '...'
            print(f'{i}. {author} {year} | {t} | {id_str}')
except:
    sys.exit(1)
"
}

# Search CrossRef
cmd_search_crossref() {
    local query="$1"
    local limit="${2:-10}"
    local encoded=$(urlencode "$query")
    local url="https://api.crossref.org/works?query=${encoded}&rows=${limit}&sort=relevance"

    cached_curl "cr_$(cache_key "$query")" "$url" "$CACHE_TTL_SEARCH" | python3 -c "
import sys, json
verbose = $VERBOSE
try:
    data = json.load(sys.stdin)
    items = data.get('message', {}).get('items', [])
    if not items:
        sys.exit(1)
    for i, w in enumerate(items[:10], 1):
        title = w.get('title', ['N/A'])[0]
        year = w.get('published', {}).get('date-parts', [[None]])[0]
        year = year[0] if year else '?'
        authors = w.get('author', [])
        author = authors[0].get('family', '?') if authors else '?'
        doi = w.get('DOI', '')
        if verbose:
            cites = w.get('is-referenced-by-count', 0)
            print(f'{i}. {title} ({year})')
            print(f'   Author: {author} | Citations: {cites}')
            if doi: print(f'   DOI: {doi}')
            print()
        else:
            t = title if len(title) <= 70 else title[:67] + '...'
            print(f'{i}. {author} {year} | {t} | DOI:{doi}')
except:
    sys.exit(1)
"
}

# Main search - tries OpenAlex (best), then Semantic Scholar, then CrossRef.
# Books only as last resort.
cmd_search() {
    local query="${1:-}"
    local limit="${2:-10}"

    if [ -z "$query" ]; then
        err "Usage: lit.sh search <query> [limit]"
        exit 1
    fi

    [ "$VERBOSE" = "1" ] && info "Searching OpenAlex for: $query"

    if cmd_search_openalex "$query" "$limit" 2>/dev/null; then
        return 0
    fi

    [ "$VERBOSE" = "1" ] && warn "No OpenAlex results. Trying Semantic Scholar..."
    if cmd_search_ss "$query" "$limit" 2>/dev/null; then
        return 0
    fi

    [ "$VERBOSE" = "1" ] && warn "No SS results. Trying CrossRef..."
    if cmd_search_crossref "$query" "$limit" 2>/dev/null; then
        return 0
    fi

    [ "$VERBOSE" = "1" ] && warn "No CrossRef results. Trying books..."
    cmd_book "$query" "$limit"
}

# DBLP search
cmd_dblp() {
    local query="${1:-}"
    local limit="${2:-10}"

    if [ -z "$query" ]; then
        err "Usage: lit.sh dblp <query> [limit]"
        exit 1
    fi

    local encoded=$(urlencode "$query")
    local url="https://dblp.org/search/publ/api?q=${encoded}&format=json&h=${limit}"

    [ "$VERBOSE" = "1" ] && info "Searching DBLP for: $query"

    cached_curl "dblp_$(cache_key "$query")" "$url" "$CACHE_TTL_SEARCH" | python3 -c "
import sys, json
verbose = $VERBOSE
try:
    data = json.load(sys.stdin)
    hits = data.get('result', {}).get('hits', {}).get('hit', [])
    if not hits:
        print('No results found')
        sys.exit(0)
    for i, h in enumerate(hits[:10], 1):
        info = h.get('info', {})
        title = info.get('title', 'N/A')
        year = info.get('year', '?')
        authors = info.get('authors', {}).get('author', [])
        if isinstance(authors, dict):
            authors = [authors]
        author = authors[0].get('text', '?').split()[-1] if authors else '?'
        venue = info.get('venue', '')
        url = info.get('url', '')
        if verbose:
            print(f'{i}. {title} ({year})')
            print(f'   Author: {author} | Venue: {venue}')
            if url: print(f'   DBLP: {url}')
            print()
        else:
            t = title if len(title) <= 60 else title[:57] + '...'
            print(f'{i}. {author} {year} | {t} | {venue}')
except Exception as e:
    print(f'Error: {e}', file=sys.stderr)
"
}

# Get BibTeX from DBLP URL
cmd_dblp_bib() {
    local url="${1:-}"

    if [ -z "$url" ]; then
        err "Usage: lit.sh dblp-bib <dblp_url>"
        exit 1
    fi

    # Convert to BibTeX URL
    local bib_url="${url%.bib}.bib"

    info "Fetching BibTeX from DBLP..."

    local result
    result=$(curl -sL --max-time "$CURL_TIMEOUT" "$bib_url")
    echo "$result"
    maybe_append_bib "$result"
}

# DOI lookup via CrossRef
cmd_doi() {
    local doi="${1:-}"

    if [ -z "$doi" ]; then
        err "Usage: lit.sh doi <doi>"
        exit 1
    fi

    doi=$(normalize_doi "$doi")
    local url="https://api.crossref.org/works/${doi}"

    [ "$VERBOSE" = "1" ] && info "Looking up DOI: $doi"

    cached_curl "doi_$(cache_key "$doi")" "$url" "$CACHE_TTL_DOI" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    msg = data.get('message', {})
    title = msg.get('title', ['N/A'])[0]
    authors = msg.get('author', [])
    author = f\"{authors[0].get('given', '')} {authors[0].get('family', '')}\" if authors else 'Unknown'
    year = msg.get('published', {}).get('date-parts', [[None]])[0][0]
    container = msg.get('container-title', ['N/A'])[0] if msg.get('container-title') else 'N/A'
    doi = msg.get('DOI', '')
    print(f'Title: {title}')
    print(f'Author: {author}')
    print(f'Year: {year}')
    print(f'Journal: {container}')
    print(f'DOI: {doi}')
except Exception as e:
    print(f'Error: {e}', file=sys.stderr)
"
}

# Get BibTeX from CrossRef
cmd_bibtex() {
    local doi="${1:-}"

    if [ -z "$doi" ]; then
        err "Usage: lit.sh bibtex <doi>"
        exit 1
    fi

    doi=$(normalize_doi "$doi")
    local url="https://api.crossref.org/works/${doi}/transform/application/x-bibtex"

    [ "$VERBOSE" = "1" ] && info "Fetching BibTeX for DOI: $doi"

    local result
    result=$(curl -sL --max-time "$CURL_TIMEOUT" "$url")
    echo "$result"
    maybe_append_bib "$result"
}

# ISBN lookup via OpenLibrary
cmd_isbn() {
    local isbn="${1:-}"

    if [ -z "$isbn" ]; then
        err "Usage: lit.sh isbn <isbn>"
        err "Example: lit.sh isbn 978-0262039246"
        exit 1
    fi

    # Strip hyphens and spaces
    isbn=$(echo "$isbn" | tr -d ' ' | tr -d '-')

    [ "$VERBOSE" = "1" ] && info "Looking up ISBN: ${isbn}"

    local url="https://openlibrary.org/api/books?bibkeys=ISBN:${isbn}&format=json&jscmd=data"
    cached_curl "isbn_${isbn}" "$url" "$CACHE_TTL_DOI" | python3 -c "
import sys, json, re
try:
    data = json.load(sys.stdin)
    if not data:
        print('No results found')
        sys.exit(1)
    key = list(data.keys())[0]
    book = data[key]

    print(f\"Title: {book.get('title', 'N/A')}\")
    if book.get('subtitle'):
        print(f\"Subtitle: {book['subtitle']}\")
    authors = book.get('authors', [])
    if authors:
        print(f\"Author: {', '.join(a['name'] for a in authors)}\")
    publishers = book.get('publishers', [])
    if publishers:
        print(f\"Publisher: {publishers[0]['name']}\")
    print(f\"Date: {book.get('publish_date', 'N/A')}\")
    print(f\"Pages: {book.get('number_of_pages', 'N/A')}\")

    ids = book.get('identifiers', {})
    if ids.get('isbn_13'):
        print(f\"ISBN-13: {ids['isbn_13'][0]}\")
    if ids.get('isbn_10'):
        print(f\"ISBN-10: {ids['isbn_10'][0]}\")

    # Generate BibTeX
    print()
    author = authors[0]['name'] if authors else 'Unknown'
    author_key = author.split()[-1].lower()
    year = book.get('publish_date', '')
    year_num = ''.join(c for c in year if c.isdigit())[-4:] if year else 'XXXX'
    title = book.get('title', '')
    if book.get('subtitle'):
        title += ': ' + book['subtitle']
    publisher = publishers[0]['name'] if publishers else ''
    isbn_val = ids.get('isbn_13', ids.get('isbn_10', ['']))[0]

    title_words = re.sub(r'[^a-zA-Z\s]', '', title).lower().split()
    skip_words = {'the', 'a', 'an', 'of', 'and', 'in', 'on', 'for', 'to', 'how', 'what', 'why', 'when'}
    title_key = next((w for w in title_words if w not in skip_words and len(w) > 2), '')

    print(f'@book{{{author_key}{year_num}{title_key},')
    print(f'  title = {{{title}}},')
    print(f'  author = {{{author}}},')
    print(f'  year = {{{year_num}}},')
    if publisher:
        print(f'  publisher = {{{publisher}}},')
    if isbn_val:
        print(f'  isbn = {{{isbn_val}}}')
    print('}')
except Exception as e:
    print(f'Error parsing response: {e}', file=sys.stderr)
    sys.exit(1)
"
}

# Book search via OpenLibrary
cmd_book() {
    local query="${1:-}"
    local limit="${2:-10}"

    if [ -z "$query" ]; then
        err "Usage: lit.sh book <query> [limit]"
        exit 1
    fi

    local encoded=$(urlencode "$query")
    local url="https://openlibrary.org/search.json?q=${encoded}&limit=${limit}"

    [ "$VERBOSE" = "1" ] && info "Searching OpenLibrary for: $query"

    cached_curl "book_$(cache_key "$query")" "$url" "$CACHE_TTL_SEARCH" | python3 -c "
import sys, json
verbose = $VERBOSE
try:
    data = json.load(sys.stdin)
    docs = data.get('docs', [])
    if not docs:
        print('No results found')
        sys.exit(0)

    for i, doc in enumerate(docs[:10], 1):
        title = doc.get('title', 'N/A')
        year = doc.get('first_publish_year', '?')
        authors = doc.get('author_name', ['?'])
        author = authors[0].split()[-1] if authors else '?'
        isbn = doc.get('isbn', [''])[0] if doc.get('isbn') else ''

        if verbose:
            print(f\"{i}. {title} ({year})\")
            print(f\"   Author: {author}\")
            if isbn: print(f\"   ISBN: {isbn}\")
            print()
        else:
            id_str = f'ISBN:{isbn}' if isbn else ''
            t = title if len(title) <= 60 else title[:57] + '...'
            print(f\"{i}. {author} {year} | {t} | {id_str}\")
except Exception as e:
    print(f'Error: {e}', file=sys.stderr)
"
}

# arXiv lookup
cmd_arxiv() {
    local arxiv_id="${1:-}"

    if [ -z "$arxiv_id" ]; then
        err "Usage: lit.sh arxiv <arxiv_id>"
        err "Example: lit.sh arxiv 2006.11239"
        exit 1
    fi

    arxiv_id=$(normalize_arxiv "$arxiv_id")
    local url="https://export.arxiv.org/api/query?id_list=${arxiv_id}"

    [ "$VERBOSE" = "1" ] && info "Looking up arXiv: $arxiv_id"

    local result
    result=$(cached_curl "arxiv_$(cache_key "$arxiv_id")" "$url" "$CACHE_TTL_DOI")
    echo "$result" | python3 -c "
import sys, re
from xml.etree import ElementTree as ET

try:
    xml = sys.stdin.read()
    root = ET.fromstring(xml)
    ns = {'atom': 'http://www.w3.org/2005/Atom'}

    entry = root.find('atom:entry', ns)
    if entry is None:
        print('Not found')
        sys.exit(1)

    title = entry.find('atom:title', ns).text.strip().replace('\n', ' ')
    summary = entry.find('atom:summary', ns).text.strip()[:200]
    published = entry.find('atom:published', ns).text[:10]
    year = published[:4]

    authors = entry.findall('atom:author/atom:name', ns)
    author_list = [a.text for a in authors]
    first_author = author_list[0] if author_list else 'Unknown'

    pdf_link = ''
    for link in entry.findall('atom:link', ns):
        if link.get('title') == 'pdf':
            pdf_link = link.get('href')

    entry_id = entry.find('atom:id', ns).text
    arxiv_id = entry_id.split('/')[-1]
    if 'v' in arxiv_id:
        arxiv_id = arxiv_id.rsplit('v', 1)[0]

    print(f'Title: {title}')
    print(f'Authors: {\", \".join(author_list[:3])}{\" et al.\" if len(author_list) > 3 else \"\"}')
    print(f'Published: {published}')
    print(f'arXiv: {arxiv_id}')
    if pdf_link:
        print(f'PDF: {pdf_link}')
    print()
    print(f'Abstract: {summary}...')
    print()

    # Generate BibTeX
    author_key = first_author.split()[-1].lower()
    title_words = re.sub(r'[^a-zA-Z\s]', '', title).lower().split()
    skip = {'the', 'a', 'an', 'of', 'and', 'in', 'on', 'for', 'to'}
    title_key = next((w for w in title_words if w not in skip and len(w) > 2), '')

    print(f'@article{{{author_key}{year}{title_key},')
    print(f'  title = {{{title}}},')
    print(f'  author = {{{\" and \".join(author_list)}}},')
    print(f'  year = {{{year}}},')
    print(f'  eprint = {{{arxiv_id}}},')
    print(f'  archivePrefix = {{arXiv}},')
    print('}')
except Exception as e:
    print(f'Error: {e}', file=sys.stderr)
"
}

# Download arXiv source
cmd_source() {
    local arxiv_id="${1:-}"
    local output_dir="${2:-.}"

    if [ -z "$arxiv_id" ]; then
        err "Usage: lit.sh source <arxiv_id> [output_dir]"
        exit 1
    fi

    arxiv_id=$(normalize_arxiv "$arxiv_id")
    local url="https://arxiv.org/e-print/${arxiv_id}"
    local output_file="${output_dir}/${arxiv_id}.tar.gz"

    info "Downloading arXiv source: $arxiv_id"

    mkdir -p "$output_dir"
    curl -sL --max-time 60 "$url" -o "$output_file"

    if [ -f "$output_file" ]; then
        echo "Downloaded: $output_file"
        echo "Extract: tar -xzf $output_file -C $output_dir"
    else
        err "Download failed"
        exit 1
    fi
}

# Find open-access PDF via Unpaywall
cmd_pdf() {
    local doi="${1:-}"

    if [ -z "$doi" ]; then
        err "Usage: lit.sh pdf <doi>"
        exit 1
    fi

    doi=$(normalize_doi "$doi")
    local email="lit@example.com"
    local url="https://api.unpaywall.org/v2/${doi}?email=${email}"

    [ "$VERBOSE" = "1" ] && info "Finding PDF for DOI: $doi"

    cached_curl "unpaywall_$(cache_key "$doi")" "$url" "$CACHE_TTL_DOI" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    title = data.get('title', 'N/A')
    print(f'Title: {title}')

    oa = data.get('best_oa_location')
    if oa:
        pdf_url = oa.get('url_for_pdf') or oa.get('url')
        print(f'PDF: {pdf_url}')
    else:
        print('No open-access PDF found')
except Exception as e:
    print(f'Error: {e}', file=sys.stderr)
"
}

# Get references of a paper
cmd_refs() {
    local paper_id="${1:-}"

    if [ -z "$paper_id" ]; then
        err "Usage: lit.sh refs <paper_id>"
        err "paper_id: DOI, arXiv ID, or Semantic Scholar ID"
        exit 1
    fi

    # Auto-prefix bare DOIs for Semantic Scholar API
    [[ "$paper_id" =~ ^10\.[0-9]{4,}/ ]] && paper_id="DOI:$paper_id"

    local url="https://api.semanticscholar.org/graph/v1/paper/${paper_id}/references?fields=title,authors,year&limit=50"

    [ "$VERBOSE" = "1" ] && info "Getting references for: $paper_id"

    cached_curl "refs_$(cache_key "$paper_id")" "$url" "$CACHE_TTL_SEARCH" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    refs = data.get('data', [])
    if not refs:
        print('No references found')
        sys.exit(0)
    for i, r in enumerate(refs[:20], 1):
        paper = r.get('citedPaper', {})
        title = paper.get('title', 'N/A')
        year = paper.get('year', '?')
        authors = paper.get('authors', [])
        author = authors[0]['name'] if authors else 'Unknown'
        print(f'{i}. {title} ({year}) - {author}')
except Exception as e:
    print(f'Error: {e}', file=sys.stderr)
"
}

# Get papers citing this paper
cmd_cites() {
    local paper_id="${1:-}"

    if [ -z "$paper_id" ]; then
        err "Usage: lit.sh cites <paper_id>"
        exit 1
    fi

    # Auto-prefix bare DOIs for Semantic Scholar API
    [[ "$paper_id" =~ ^10\.[0-9]{4,}/ ]] && paper_id="DOI:$paper_id"

    local url="https://api.semanticscholar.org/graph/v1/paper/${paper_id}/citations?fields=title,authors,year&limit=50"

    [ "$VERBOSE" = "1" ] && info "Getting citations for: $paper_id"

    cached_curl "cites_$(cache_key "$paper_id")" "$url" "$CACHE_TTL_SEARCH" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    cites = data.get('data', [])
    if not cites:
        print('No citations found')
        sys.exit(0)
    for i, c in enumerate(cites[:20], 1):
        paper = c.get('citingPaper', {})
        title = paper.get('title', 'N/A')
        year = paper.get('year', '?')
        authors = paper.get('authors', [])
        author = authors[0]['name'] if authors else 'Unknown'
        print(f'{i}. {title} ({year}) - {author}')
except Exception as e:
    print(f'Error: {e}', file=sys.stderr)
"
}

# Open paper in browser
cmd_open() {
    local input="${1:-}"

    if [ -z "$input" ]; then
        err "Usage: lit.sh open <arxiv_id|doi|url>"
        exit 1
    fi

    local url=""
    local type=$(detect_type "$input")

    case "$type" in
        arxiv)
            local id=$(normalize_arxiv "$input")
            url="https://arxiv.org/abs/${id}"
            ;;
        doi)
            local id=$(normalize_doi "$input")
            url="https://doi.org/${id}"
            ;;
        dblp_url|ss_url)
            url="$input"
            ;;
        isbn)
            local stripped=$(echo "$input" | tr -d '- ')
            url="https://openlibrary.org/isbn/${stripped}"
            ;;
        *)
            # Treat as Semantic Scholar search
            local encoded=$(urlencode "$input")
            url="https://www.semanticscholar.org/search?q=${encoded}"
            ;;
    esac

    info "Opening: $url"
    if command -v open &>/dev/null; then
        open "$url"
    elif command -v xdg-open &>/dev/null; then
        xdg-open "$url"
    else
        echo "$url"
    fi
}

# Fetch BibTeX and append to .bib file
cmd_add() {
    local input="${1:-}"
    local bib_file="${2:-}"

    if [ -z "$input" ] || [ -z "$bib_file" ]; then
        err "Usage: lit.sh add <arxiv_id|doi> <bib_file>"
        exit 1
    fi

    local type=$(detect_type "$input")
    local bibtex=""

    case "$type" in
        arxiv)
            local id=$(normalize_arxiv "$input")
            # Fetch arXiv and extract BibTeX block
            bibtex=$(cmd_arxiv "$id" 2>/dev/null | sed -n '/^@/,/^}/p')
            ;;
        doi)
            local id=$(normalize_doi "$input")
            bibtex=$(curl -sL --max-time "$CURL_TIMEOUT" "https://api.crossref.org/works/${id}/transform/application/x-bibtex" 2>/dev/null)
            ;;
        isbn)
            local stripped=$(echo "$input" | tr -d '- ')
            bibtex=$(cmd_isbn "$stripped" 2>/dev/null | sed -n '/^@/,/^}/p')
            ;;
        *)
            err "Cannot auto-detect BibTeX source for: $input"
            err "Provide an arXiv ID, DOI, or ISBN"
            exit 1
            ;;
    esac

    if [ -z "$bibtex" ] || [[ "$bibtex" != @* ]]; then
        err "Failed to fetch BibTeX"
        exit 1
    fi

    # Append to file
    if [ -f "$bib_file" ]; then
        echo "" >> "$bib_file"
    fi
    echo "$bibtex" >> "$bib_file"

    # Extract key for confirmation
    local key=$(echo "$bibtex" | head -1 | sed 's/@[^{]*{//; s/,$//')
    echo "Added $key to $bib_file"
    echo "$bibtex"
}

# Helper: append BibTeX to file if --bib was specified
maybe_append_bib() {
    local bibtex="$1"
    if [ -n "$BIB_FILE" ] && [[ "$bibtex" == *@* ]]; then
        local bib_block=$(echo "$bibtex" | sed -n '/^[[:space:]]*@/,/^[[:space:]]*}/p')
        if [ -n "$bib_block" ]; then
            if [ -f "$BIB_FILE" ]; then
                echo "" >> "$BIB_FILE"
            fi
            echo "$bib_block" >> "$BIB_FILE"
            local key=$(echo "$bib_block" | head -1 | sed 's/.*@[^{]*{//; s/,$//')
            info "Appended $key to $BIB_FILE"
        fi
    fi
}

# Verify bib file entries
cmd_verify() {
    local bib_file="${1:-}"
    local parallel_jobs="${2:-4}"

    if [ -z "$bib_file" ] || [ ! -f "$bib_file" ]; then
        err "Usage: lit.sh verify <bib_file> [parallel_jobs]"
        exit 1
    fi

    info "Verifying entries in: $bib_file"

    # Export BEFORE the heredoc that reads it
    export _LIT_BIB_FILE="$bib_file"

    # Extract entries from bib file
    local entries_file=$(mktemp)
    python3 << 'PYEOF' > "$entries_file"
import re, sys, os

bib_file = os.environ.get('_LIT_BIB_FILE', '')
with open(bib_file, 'r') as f:
    content = f.read()

pattern = r'@(\w+)\s*\{\s*([^,]+)\s*,([^@]*?)(?=\n@|\n*$)'
for m in re.finditer(pattern, content, re.DOTALL):
    entry_type = m.group(1).lower()
    key = m.group(2).strip()
    fields = m.group(3)

    start = m.start()
    before = content[max(0, start-200):start]
    if '% lit:skip' in before.split('\n')[-3:]:
        continue

    title = author = year = doi = eprint = ''
    for field_match in re.finditer(r'(\w+)\s*=\s*[{"]([^}"]*)[}"]', fields):
        fname = field_match.group(1).lower()
        fval = field_match.group(2).strip()
        if fname == 'title':
            title = re.sub(r'[{}]', '', fval)
        elif fname == 'author':
            author = fval.split(' and ')[0].split(',')[0].split()[-1]
        elif fname == 'year':
            year = fval
        elif fname == 'doi':
            doi = fval
        elif fname == 'eprint':
            eprint = fval

    if title:
        print(f'{entry_type}|{key}|{title}|{author}|{year}|{doi}|{eprint}')
PYEOF

    local total=$(wc -l < "$entries_file" | tr -d ' ')
    echo "Found $total entries to verify"
    echo ""

    # Verify single entry function
    verify_single() {
        local line="$1"
        IFS='|' read -r entry_type key title author year doi eprint <<< "$line"

        # Pass values via env vars (safe from injection)
        _V_TITLE="$title" _V_AUTHOR="$author" _V_YEAR="$year" \
        _V_DOI="$doi" _V_EPRINT="$eprint" _V_KEY="$key" \
        _V_ENTRY_TYPE="$entry_type" \
        python3 << 'PYEOF'
import os, sys, json, re, urllib.request, urllib.parse, ssl, hashlib, time

ctx = ssl.create_default_context()
ctx.check_hostname = False
ctx.verify_mode = ssl.CERT_NONE

CACHE_DIR = os.environ.get('LIT_CACHE_DIR', 'etc/lit/cache')
CACHE_TTL = 86400

title = os.environ.get('_V_TITLE', '')
author = os.environ.get('_V_AUTHOR', '')
year = os.environ.get('_V_YEAR', '')
doi = os.environ.get('_V_DOI', '')
eprint = os.environ.get('_V_EPRINT', '')
key = os.environ.get('_V_KEY', '')
entry_type = os.environ.get('_V_ENTRY_TYPE', '')
is_book = entry_type == 'book'

def fetch(url, headers=None):
    cache_key = hashlib.md5(url.encode()).hexdigest()[:16]
    cache_file = os.path.join(CACHE_DIR, cache_key)
    try:
        if os.path.exists(cache_file):
            mtime = os.path.getmtime(cache_file)
            if time.time() - mtime < CACHE_TTL:
                with open(cache_file, 'r') as f:
                    return f.read()
    except:
        pass

    req = urllib.request.Request(url, headers=headers or {})
    try:
        with urllib.request.urlopen(req, timeout=15, context=ctx) as resp:
            data = resp.read().decode('utf-8')
            try:
                os.makedirs(CACHE_DIR, exist_ok=True)
                with open(cache_file, 'w') as f:
                    f.write(data)
            except:
                pass
            return data
    except urllib.error.HTTPError as e:
        if e.code == 429:
            api = 'SS' if 'semanticscholar' in url else 'API'
            print(f'RATE_LIMIT:{api}', file=sys.stderr)
        return ''
    except:
        return ''

status = 'UNKNOWN'
source = ''
found_title = ''
found_year = ''
found_author = ''
issues = []

if doi:
    url = f'https://api.crossref.org/works/{doi}'
    result = fetch(url)
    if result and '"title"' in result:
        try:
            d = json.loads(result)
            msg = d.get('message', {})
            found_title = msg.get('title', [''])[0]
            found_year = str(msg.get('published', {}).get('date-parts', [[None]])[0][0] or '')
            auths = msg.get('author', [])
            found_author = auths[0].get('family', '') if auths else ''
            status = 'OK'
            source = 'DOI'
        except:
            pass

if eprint and status == 'UNKNOWN':
    url = f'https://export.arxiv.org/api/query?id_list={eprint}'
    result = fetch(url)
    if result and '<entry>' in result:
        try:
            import xml.etree.ElementTree as ET
            root = ET.fromstring(result)
            ns = {'atom': 'http://www.w3.org/2005/Atom'}
            entry = root.find('atom:entry', ns)
            if entry is not None:
                found_title = entry.find('atom:title', ns).text.strip()
                published = entry.find('atom:published', ns).text[:4]
                found_year = published
                authors = entry.findall('atom:author/atom:name', ns)
                found_author = authors[0].text.split()[-1] if authors else ''
                status = 'OK'
                source = 'arXiv'
        except:
            pass

if title and status == 'UNKNOWN':
    search_title = title
    if len(search_title) > 60:
        search_title = search_title[:60].rsplit(' ', 1)[0]
    query = urllib.parse.quote(search_title)
    url = f'https://api.openalex.org/works?filter=title.search:{query}&per-page=5'
    result = fetch(url)
    if result and '"results":' in result:
        try:
            d = json.loads(result)
            results_list = d.get('results', [])

            best_match = None
            best_score = 0
            best_author_match = False
            title_norm = re.sub(r'[^a-z0-9]', '', title.lower())
            author_norm = re.sub(r'[^a-z]', '', author.lower()) if author else ''

            for p in results_list:
                pt = p.get('title', '')
                pt_norm = re.sub(r'[^a-z0-9]', '', pt.lower())

                prefix_len = 0
                for i in range(min(len(title_norm), len(pt_norm))):
                    if title_norm[i] == pt_norm[i]:
                        prefix_len += 1
                    else:
                        break

                p_auths = p.get('authorships', [])
                p_auth_names = ' '.join(a.get('author', {}).get('display_name', '') for a in p_auths).lower()
                if author_norm:
                    if len(author_norm) >= 4:
                        has_author_match = author_norm[:4] in p_auth_names
                    else:
                        has_author_match = f' {author_norm} ' in f' {p_auth_names} '
                else:
                    has_author_match = True

                score = prefix_len
                py = str(p.get('publication_year', ''))
                title_match_ok = prefix_len >= 15 or (prefix_len >= 10 and prefix_len >= len(title_norm) * 0.8)
                if title_match_ok:
                    if year and py == year:
                        score += 10
                    if has_author_match:
                        score += 15

                if score > best_score:
                    best_score = score
                    best_match = p
                    best_author_match = has_author_match

            if best_match and ((best_score >= 20 and best_author_match) or best_score >= 35):
                found_title = best_match.get('title', '')
                found_year = str(best_match.get('publication_year', ''))
                auths = best_match.get('authorships', [])
                if auths:
                    found_author = auths[0].get('author', {}).get('display_name', '').split()[-1]

                found_doi = best_match.get('doi', '')
                year_close = False
                if year and found_year:
                    try:
                        year_close = abs(int(year) - int(found_year)) <= 3
                    except ValueError:
                        year_close = False
                if found_doi and not doi and best_author_match and year_close:
                    found_doi = found_doi.replace('https://doi.org/', '')
                    is_proceedings = entry_type in ('inproceedings', 'conference')
                    if 'arxiv' in found_doi.lower():
                        if not is_proceedings:
                            issues.append(f'arxiv-doi:{found_doi}')
                    else:
                        issues.append(f'add-doi:{found_doi}')

                if found_title:
                    if best_author_match:
                        status = 'OK'
                        source = 'OpenAlex'
                    else:
                        status = 'TENTATIVE'
                        source = 'OpenAlex'
        except:
            pass

if title and status in ('UNKNOWN', 'TENTATIVE'):
    search_query = f'{title[:80]} {author}'
    query = urllib.parse.quote(search_query)
    url = f'https://api.semanticscholar.org/graph/v1/paper/search?query={query}&limit=5&fields=title,authors,year,externalIds'
    result = fetch(url)
    if result and '"data":' in result:
        try:
            d = json.loads(result)
            results_list = d.get('data', [])
            title_norm = re.sub(r'[^a-z0-9]', '', title.lower())
            author_norm = re.sub(r'[^a-z]', '', author.lower()) if author else ''

            for p in results_list:
                pt = p.get('title', '')
                pt_norm = re.sub(r'[^a-z0-9]', '', pt.lower())

                prefix_len = 0
                for i in range(min(len(title_norm), len(pt_norm))):
                    if title_norm[i] == pt_norm[i]:
                        prefix_len += 1
                    else:
                        break

                p_auths = p.get('authors', [])
                p_auth_names = ' '.join(a.get('name', '') for a in p_auths).lower()
                if author_norm:
                    if len(author_norm) >= 4:
                        has_author_match = author_norm[:4] in p_auth_names
                    else:
                        has_author_match = f' {author_norm} ' in f' {p_auth_names} '
                else:
                    has_author_match = True

                title_match_ok = prefix_len >= 15 or (prefix_len >= 10 and prefix_len >= len(title_norm) * 0.8)
                if title_match_ok and has_author_match:
                    found_title = pt
                    found_year = str(p.get('year', ''))
                    found_author = p_auths[0].get('name', '').split()[-1] if p_auths else ''
                    status = 'OK'
                    source = 'SemanticScholar'
                    break
        except:
            pass

if is_book and status == 'UNKNOWN':
    search_query = f'{title[:50]} {author}'
    query = urllib.parse.quote(search_query)
    url = f'https://openlibrary.org/search.json?q={query}&limit=5'
    result = fetch(url)
    if result and '"docs":' in result:
        try:
            d = json.loads(result)
            docs = d.get('docs', [])
            title_norm = re.sub(r'[^a-z0-9]', '', title.lower())

            for doc in docs:
                dt = doc.get('title', '')
                dt_norm = re.sub(r'[^a-z0-9]', '', dt.lower())

                if title_norm[:20] == dt_norm[:20]:
                    found_title = dt
                    found_year = str(doc.get('first_publish_year', ''))
                    doc_authors = doc.get('author_name', [])
                    found_author = doc_authors[0].split()[-1] if doc_authors else ''
                    status = 'BOOK'
                    source = 'OpenLibrary'
                    break
        except:
            pass

if status == 'OK' or status == 'TENTATIVE':
    if year and found_year and year != found_year:
        issues.append(f'year:{year}->{found_year}')
    if author and found_author:
        author_norm = re.sub(r'[^a-z]', '', author.lower())
        found_norm = re.sub(r'[^a-z]', '', found_author.lower())
        if author_norm[:4] != found_norm[:4] if len(author_norm) >= 4 else author_norm != found_norm:
            issues.append(f'author:{author}->{found_author}')
    if title and found_title:
        title_norm = re.sub(r'[^a-z0-9]', '', title.lower())
        found_norm = re.sub(r'[^a-z0-9]', '', found_title.lower())
        if title_norm[:30] != found_norm[:30]:
            issues.append('title-mismatch')

real_issues = [i for i in issues if not i.startswith('add-doi:') and not i.startswith('arxiv-doi:')]
if real_issues and status == 'OK':
    status = 'MISMATCH'

issues_str = ' '.join(issues)
print(f'{status}|{source}|{key}|{title[:50]}|{issues_str}')
PYEOF
    }

    export -f verify_single
    export CURL_TIMEOUT
    export LIT_CACHE_DIR="$CACHE_DIR"

    info "Verifying entries (parallel=$parallel_jobs)..."
    echo ""

    # Run verification in parallel
    local rate_limit_file=$(mktemp)
    local results=$(cat "$entries_file" | tr '\n' '\0' | xargs -0 -P "$parallel_jobs" -I {} bash -c 'verify_single "$@" 2>&1' _ {} | tee >(grep "^RATE_LIMIT:" > "$rate_limit_file" 2>/dev/null || true) | grep -v "^RATE_LIMIT:" || true)

    local ok=$(echo "$results" | grep -c "^OK" || true)
    local mismatch=$(echo "$results" | grep -c "^MISMATCH" || true)
    local unknown=$(echo "$results" | grep -c "^UNKNOWN" || true)
    local book=$(echo "$results" | grep -c "^BOOK" || true)
    local manual=$(grep -c "% lit:skip" "$bib_file" 2>/dev/null || true)

    echo "$results" | while IFS='|' read -r status source key title issues; do
        case "$status" in
            OK)
                if [ -n "$issues" ]; then
                    echo -e "  ${YELLOW}!${NC} ${key} [${source}]: ${issues}"
                fi
                ;;
            MISMATCH)
                echo -e "  ${RED}!${NC} ${key} [${source}]: ${issues}"
                ;;
            BOOK)
                echo -e "  ${BLUE}B${NC} ${key} [${source}]: ${title}"
                ;;
            UNKNOWN)
                echo -e "  ${RED}x${NC} ${key}: ${title}"
                ;;
        esac
    done

    local rate_limits=$(wc -l < "$rate_limit_file" 2>/dev/null | tr -d ' ')
    if [ "${rate_limits:-0}" -gt 0 ]; then
        echo ""
        warn "Warning: $rate_limits API rate limit(s) hit. Run again or reduce parallel jobs."
    fi

    echo ""
    local verified=$((ok + manual))
    echo "Total: $total | OK: $verified (auto:$ok manual:$manual) | Mismatch: $mismatch | Books: $book | Not found: $unknown"

    rm -f "$entries_file" "$rate_limit_file"
    [ "$unknown" -eq 0 ] && [ "$mismatch" -eq 0 ]
}

# Help
cmd_help() {
    echo "lit.sh - Literature search tool"
    echo ""
    echo "Usage: lit.sh [flags] [command] <input>"
    echo ""
    echo "Smart detection (just paste anything):"
    echo "  lit.sh 2006.11239                   arXiv lookup"
    echo "  lit.sh 10.1145/3442188.3445899      DOI lookup"
    echo "  lit.sh https://arxiv.org/abs/...    arXiv lookup"
    echo "  lit.sh https://doi.org/10.1145/...  DOI lookup"
    echo "  lit.sh 978-0262039246               ISBN lookup"
    echo "  lit.sh \"deep learning\"              Search papers"
    echo ""
    echo "Commands:"
    echo "  search <query> [limit]  Search papers (SS -> OpenAlex -> Books)"
    echo "  dblp <query> [limit]    Search DBLP for CS venue papers"
    echo "  dblp-bib <dblp_url>     Get BibTeX from DBLP URL"
    echo "  doi <doi>               Lookup paper by DOI (CrossRef)"
    echo "  bibtex <doi>            Get BibTeX for DOI (CrossRef)"
    echo "  isbn <isbn>             Lookup book by ISBN (OpenLibrary)"
    echo "  book <query> [limit]    Search books (OpenLibrary)"
    echo "  arxiv <id>              arXiv paper info + BibTeX"
    echo "  source <id> [dir]       Download arXiv LaTeX source"
    echo "  pdf <doi>               Find open-access PDF (Unpaywall)"
    echo "  refs <paper_id>         Get references of a paper"
    echo "  cites <paper_id>        Get citing papers"
    echo "  open <id>               Open paper in browser"
    echo "  add <id> <bib_file>     Fetch BibTeX and append to file"
    echo "  verify <bib_file> [n]   Verify .bib entries (parallel=n)"
    echo ""
    echo "Flags:"
    echo "  -v, --verbose           Full details (default: concise)"
    echo "  --bib <file>            Append fetched BibTeX to file"
    echo ""
    echo "Environment:"
    echo "  LIT_CACHE_DIR           Cache dir (default: etc/lit/cache)"
    echo "  CURL_TIMEOUT            Timeout in seconds (default: 15)"
}

# ── Flag parsing ─────────────────────────────────────────────────────

while [[ "${1:-}" == -* ]]; do
    case "$1" in
        -v|--verbose) VERBOSE=1; shift ;;
        --bib)
            if [ -z "${2:-}" ]; then
                err "--bib requires a filename"
                exit 1
            fi
            BIB_FILE="$2"; shift 2
            ;;
        -h|--help) cmd_help; exit 0 ;;
        *) break ;;
    esac
done

# ── Main dispatcher ──────────────────────────────────────────────────

cmd="${1:-help}"

# Check if first arg is an explicit command
case "$cmd" in
    search)     shift; cmd_search "${1:-}" "${2:-10}" ;;
    dblp)       shift; cmd_dblp "${1:-}" "${2:-10}" ;;
    dblp-bib)   shift; cmd_dblp_bib "${1:-}" ;;
    doi)        shift; cmd_doi "${1:-}" ;;
    bibtex|bib) shift; cmd_bibtex "${1:-}" ;;
    isbn)       shift; cmd_isbn "${1:-}" ;;
    book)       shift; cmd_book "${1:-}" "${2:-10}" ;;
    arxiv)      shift; cmd_arxiv "${1:-}" ;;
    source)     shift; cmd_source "${1:-}" "${2:-.}" ;;
    pdf)        shift; cmd_pdf "${1:-}" ;;
    refs)       shift; cmd_refs "${1:-}" ;;
    cites)      shift; cmd_cites "${1:-}" ;;
    open)       shift; cmd_open "${1:-}" ;;
    add)        shift; cmd_add "${1:-}" "${2:-}" ;;
    verify)     shift; cmd_verify "${1:-}" "${2:-4}" ;;
    help|--help|-h) cmd_help ;;
    *)
        # Auto-detect: not a known command, so treat the whole input as a query
        type=$(detect_type "$cmd")
        case "$type" in
            arxiv)    cmd_arxiv "$cmd" ;;
            doi)      cmd_doi "$cmd" ;;
            isbn)     cmd_isbn "$cmd" ;;
            dblp_url) cmd_dblp_bib "$cmd" ;;
            ss_url)   cmd_open "$cmd" ;;
            search)   cmd_search "$cmd" "${2:-10}" ;;
        esac
        ;;
esac
